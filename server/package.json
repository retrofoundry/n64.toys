{
  "name": "@n64-toys/server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node dist/db/migrate.js",
    "db:verify": "node dist/db/verify.js",
    "db:roundtrip": "node scripts/round-trip.mjs"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.6.23",
    "@hono/node-server": "2.0.8",
    "better-auth": "1.6.23",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.30",
    "pg": "^8.22.0",
    "pngjs": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/pg": "^8.20.0",
    "@types/pngjs": "^6.0.5",
    "auth": "1.6.23",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  }
}
